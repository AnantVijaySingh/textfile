/**
 * This is a Cloudflare Pages Function that acts as a signaling server for y-webrtc.
 * It lives within the same project as the main website and responds to requests
 * on the `/signaling` path.
 *
 * The file path `functions/signaling/[[path]].js` is special. It routes all requests
 * from `your-domain.com/signaling/*` to this file.
 */

/**
 * The Durable Object class for a signaling room.
 * This code remains unchanged from the original worker.
 */
export class SignalingRoom {
  constructor(state, env) {
    this.state = state;
    this.sessions = [];
  }

  // Handle HTTP requests (for WebSocket upgrades)
  async fetch(request) {
    // Expecting a WebSocket upgrade request
    const upgradeHeader = request.headers.get('Upgrade');
    if (!upgradeHeader || upgradeHeader !== 'websocket') {
      return new Response('Expected Upgrade: websocket', { status: 426 });
    }

    const [client, server] = Object.values(new WebSocketPair());
    await this.handleSession(server);

    return new Response(null, {
      status: 101,
      webSocket: client,
    });
  }

  // Handle a new WebSocket session
  async handleSession(socket) {
    socket.accept();
    const session = { socket, messages: [] };
    this.sessions.push(session);

    socket.addEventListener('message', async (event) => {
      try {
        const message = JSON.parse(event.data);
        this.broadcast(session, message);
      } catch (err) {
        console.error('Failed to parse or broadcast message:', err);
      }
    });

    socket.addEventListener('close', () => {
      this.sessions = this.sessions.filter((s) => s !== session);
    });
    
    socket.addEventListener('error', (err) => {
        console.error('WebSocket error:', err);
    });
  }

  // Broadcast a message to all other sessions in the room
  broadcast(sender, message) {
    const messageString = JSON.stringify(message);
    this.sessions.forEach((session) => {
      if (session !== sender && session.socket.readyState === WebSocket.READY_STATE_OPEN) {
        try {
            session.socket.send(messageString);
        } catch (err) {
            console.error('Failed to send message to a session:', err);
        }
      }
    });
  }
}

/**
 * This is the main fetch handler for the Pages Function.
 * It gets the request and forwards it to the correct Durable Object instance.
 */
export async function onRequest(context) {
  const { request, env } = context;
  const url = new URL(request.url);

  // The room name is now part of the path, e.g., /signaling/room-name
  // We extract it to create a unique Durable Object for each room.
  const roomName = url.pathname.replace('/signaling/', '');

  if (!roomName) {
    return new Response('Invalid signaling URL', { status: 400 });
  }

  const id = env.ROOMS.idFromName(roomName);
  const room = env.ROOMS.get(id);

  // Forward the request to the Durable Object.
  return room.fetch(request);
}
